mysql:
  host: localhost
  port: 3306
  user: root
  password: your_mysql_password
  database: bbs_demo

redis:
  host: localhost
  port: 6379
  password: ""
  db: 0

kafka:
  brokers:
    - localhost:9092
  topic: bbs_demo
  group_id: bbs_demo_group
  path: C:\kafka_2.13-4.2.0

server:
  port: 8080

logger:
  level: info
  max_size: 100
  max_backups: 3
  max_age: 30
  compress: false
  output_path: logs

jwt:
  secret: your_jwt_secret

email:
  host: smtp.qq.com
  port: 587
  username: your_email@foxmail.com
  password: your_email_password
  from: your_email@foxmail.com

elasticsearch:
  host: localhost
  port: 9201
  username: "elastic"
  password: "your_elasticsearch_password"
  index: eyuforum

ai:
  model: deepseek-chat
  api_key: your-deepseek-api-key
  api_base: https://api.deepseek.com
  timeout: 300
  max_tokens: 1000
  temperature: 0.7

upload:
  path: uploads
  max_size: 10485760
  allowed_ext: .jpg,.jpeg,.png,.gif,.webp
